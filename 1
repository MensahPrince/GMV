use clap::Parser as ClapParser;
use clap::Subcommand;
use std::io::{self, Write};

mod logic;
use crate::logic::functions::add_gmv;
use crate::logic::functions::init_gmv;

#[derive(clap::Parser, Debug)]
#[command(name = "gmv")]
#[command(about = "A GIT minimal version")]
pub struct Cli {
    #[command(subcommand)]
    pub command: Commands,
}

#[derive(Subcommand, Debug)]
pub enum Commands {
    /// Initialize a new .gmv
    Init {
        path: String,
    },

    /// Quit the GMV
    Quit,
    Exit,

    /// List the elements in the directory
    Ls,

    /// Add a change for staging
    Add {
        path: String,
    },
}

struct InputParser;

impl InputParser {
    fn new() -> Self {
        InputParser
    }

    fn parse(&self, input: &str) -> Result<Cli, clap::Error> {
        let trimmed = input.trim();

        if trimmed.is_empty() {
            // Using try_parse_from with just the binary name will trigger help if required,
            // but since we want to force help on empty input in the REPL:
            return ClapParser::try_parse_from(vec!["gmv", "--help"]);
        }

        let mut words = vec!["gmv"];
        let split_words: Vec<&str> = trimmed.split_whitespace().collect();

        // If the user already typed 'gmv', don't add it again
        if !split_words.is_empty() && split_words[0] == "gmv" {
            ClapParser::try_parse_from(split_words)
        } else {
            words.extend(split_words);
            ClapParser::try_parse_from(words)
        }
    }
}

//Call and create neccessary dirs during the init of gmv
fn main() {
    let parser = InputParser::new();

    loop {
        print!("gmv> ");
        io::stdout().flush().expect("Failed to flush stdout");

        let mut input_line = String::new();

        io::stdin()
            .read_line(&mut input_line)
            .expect("Failed to read line");

        let trimmed_input = input_line.trim();

        if trimmed_input.is_empty() {
            continue;
        }

        match parser.parse(trimmed_input) {
            Ok(cli) => match cli.command {
                Commands::Init { path } => {
                    if let Err(e) = init_gmv(&path) {
                        println!("gmv: error: {}", e);
                    } else {
                        println!("Initialized GMV at {}", path);
                    }
                }
                Commands::Quit | Commands::Exit => {
                    println!("Exiting...");
                    break;
                }

                Commands::Ls => match std::fs::read_dir(".") {
                    Ok(entries) => {
                        for entry in entries.flatten() {
                            let file_name = entry.file_name();
                            let display_name = file_name.to_string_lossy();
                            let is_dir = entry.metadata().map(|m| m.is_dir()).unwrap_or(false);
                            if is_dir {
                                println!("{}/", display_name);
                            } else {
                                println!("{}", display_name);
                            }
                        }
                    }
                    Err(e) => println!("gmv: ls error: {}", e),
                },
                Commands::Add { path } => {
                    if let Err(e) = add_gmv(path) {
                        println!("gmv: error: {}", e);
                    }
                }
            },
            Err(e) => {
                let _ = e.print();
                println!();
            }
        }
    }
}
